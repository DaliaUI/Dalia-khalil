{{ 'hero.css' | asset_url | stylesheet_tag }}


{% style %}
  .hero {
    --hero-padding-top: {{ section.settings.padding_top | default: 0 }}px;
    --hero-padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
  }
  .hero__header { position: relative; z-index: 9999 !important; }
  .hero__media-wrapper { z-index: 0 !important; }
{% endstyle %}

<section id="hero-{{ section.id }}" class="hero">
  <header class="hero__header">
    <div class="hero__branding">
      {% if section.settings.logo_1 %}
        <div class="hero__brand-mark">
          {{ section.settings.logo_1 | image_tag: alt: section.settings.logo_1_alt, loading: 'lazy', decoding: 'async' }}
        </div>
      {% else %}
        <div class="hero__brand-mark">
          <img src="{{ 'Group 1000007777.svg' | asset_url }}" alt="{{ section.settings.logo_1_alt | default: 'Logo 1' }}" loading="lazy" decoding="async" />
        </div>
      {% endif %}

      {% if section.settings.logo_2 %}
        <div class="hero__brand-mark">
          {{ section.settings.logo_2 | image_tag: alt: section.settings.logo_2_alt, loading: 'lazy', decoding: 'async' }}
        </div>
      {% else %}
        <div class="hero__brand-mark">
          <img src="{{ 'Group 1000008197.png' | asset_url }}" alt="{{ section.settings.logo_2_alt | default: 'Logo 2' }}" loading="lazy" decoding="async" />
        </div>
      {% endif %}
    </div>

    {% if section.settings.header_announcement != blank %}
      <p class="hero__announcement hero__announcement--header">{{ section.settings.header_announcement | escape }}</p>
    {% endif %}

    {% if section.settings.header_button_text != blank %}
      <a href="{{ section.settings.header_button_url | default: '#' }}" class="hero__button hero__button--header" aria-label="{{ section.settings.header_button_text | escape }}">
        {{ section.settings.header_button_text | escape }}
        {% if section.settings.header_arrow_icon %}
          {{ section.settings.header_arrow_icon | image_tag: alt: '', loading: 'lazy', decoding: 'async', class: 'hero__icon' }}
        {% else %}
          <span class="hero__icon hero__icon--placeholder" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'hero__icon-placeholder' }}</span>
        {% endif %}
      </a>
    {% endif %}
  </header>

  <main class="hero__main">
    <div class="hero__content">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'text' %}
            <div class="hero__text-block" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {% when 'button' %}
            <a
              href="{{ block.settings.link | default: '#' }}"
              class="hero__button hero__button--cta {{ block.settings.style_class | default: 'button-custom' }}"
              aria-label="{{ block.settings.label | escape }}"
              {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
              {% if block.settings.custom_button_background != blank %}style="background-color: {{ block.settings.custom_button_background }};"{% endif %}
              {{ block.shopify_attributes }}
            >
              <span>{{ block.settings.label | escape }}</span>
              {% if section.settings.cta_arrow_icon %}
                {{ section.settings.cta_arrow_icon | image_tag: alt: '', loading: 'lazy', decoding: 'async', class: 'hero__icon' }}
              {% else %}
                <span class="hero__icon hero__icon--placeholder" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'hero__icon-placeholder' }}</span>
              {% endif %}
            </a>
        {% endcase %}
      {% endfor %}
    </div>

    <div class="hero__media-wrapper">
      <picture class="hero__media">
        {% if section.settings.mobile_image %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 800, format: 'pjpg' }}" />
        {% endif %}

        {% if section.settings.desktop_image %}
          <img
            class="hero__image"
            src="{{ section.settings.desktop_image | image_url: width: 1440, format: 'pjpg' }}"
            srcset="{{ section.settings.desktop_image | image_url: width: 1440, format: 'pjpg' }} 1x, {{ section.settings.desktop_image | image_url: width: 2400, format: 'pjpg' }} 2x"
            alt="{{ section.settings.hero_title | default: 'Hero image' | escape }}"
            loading="eager"
            decoding="async"
          />
        {% elsif section.settings.mobile_image %}
          <img
            class="hero__image"
            src="{{ section.settings.mobile_image | image_url: width: 800, format: 'pjpg' }}"
            alt="{{ section.settings.hero_title | default: 'Hero image' | escape }}"
            loading="eager"
            decoding="async"
          />
        {% else %}
          <img
            class="hero__image"
            src="{{ 'banner.png' | asset_url }}"
            alt="{{ section.settings.hero_title | default: 'Hero image' | escape }}"
            loading="eager"
            decoding="async"
          />
        {% else %}
          <div class="hero__image hero__image--placeholder" aria-hidden="true">
            {{ 'image' | placeholder_svg_tag: 'hero__placeholder-image' }}
          </div>
        {% endif %}
      </picture>
    </div>
  </main>

  {% if section.settings.footer_announcement != blank %}
    <footer class="hero__footer">
      <p class="hero__announcement hero__announcement--footer">{{ section.settings.footer_announcement | escape }}</p>
    </footer>
  {% endif %}
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "logo_1",
      "label": "Logo 1"
    },
    {
      "type": "text",
      "id": "logo_1_alt",
      "label": "Logo 1 alt text",
      "default": "Logo 1"
    },
    {
      "type": "image_picker",
      "id": "logo_2",
      "label": "Logo 2"
    },
    {
      "type": "text",
      "id": "logo_2_alt",
      "label": "Logo 2 alt text",
      "default": "Logo 2"
    },
    {
      "type": "text",
      "id": "header_announcement",
      "label": "Header announcement",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "header_button_text",
      "label": "Header button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "header_button_url",
      "label": "Header button URL"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "CTA URL"
    },
    {
      "type": "text",
      "id": "footer_announcement",
      "label": "Footer announcement",
      "default": "Sustainable, Ethically Made Clothes In Sizes XS To 6XL"
    },
    {
      "type": "image_picker",
      "id": "header_arrow_icon",
      "label": "Header arrow icon"
    },
    {
      "type": "image_picker",
      "id": "cta_arrow_icon",
      "label": "CTA arrow icon"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Heading",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Browse our latest products</p>"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "options": [
            { "value": "fit-content", "label": "Fit content" },
            { "value": "fill", "label": "Fill" }
          ],
          "default": "fit-content"
        },
        {
          "type": "select",
          "id": "max_width",
          "label": "Max width",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "full", "label": "Full" }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "select",
          "id": "type_preset",
          "label": "Type preset",
          "options": [
            { "value": "h2", "label": "Heading 2" },
            { "value": "h3", "label": "Heading 3" },
            { "value": "h4", "label": "Heading 4" },
            { "value": "rte", "label": "Rich text" }
          ],
          "default": "h2"
        },
        {
          "type": "font",
          "id": "font",
          "label": "Font"
        },
        {
          "type": "select",
          "id": "font_size",
          "label": "Font size",
          "options": [
            { "value": "1rem", "label": "1rem" },
            { "value": "1.25rem", "label": "1.25rem" },
            { "value": "2rem", "label": "2rem" }
          ],
          "default": "1rem"
        },
        {
          "type": "select",
          "id": "line_height",
