{{ 'hero.css' | asset_url | stylesheet_tag }}


{% style %}
  .hero {
    --hero-padding-top: {{ section.settings.padding_top }}px;
    --hero-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section id="hero-{{ section.id }}" class="hero">
  <header class="hero__header">
    <div class="hero__branding">
      {% if section.settings.logo_1 %}
        <div class="hero__brand-mark">
          {{ section.settings.logo_1 | image_tag: alt: section.settings.logo_1_alt, loading: 'lazy', decoding: 'async' }}
        </div>
      {% else %}
        <div class="hero__brand-mark hero__brand-mark--placeholder" aria-hidden="true">
          {{ 'image' | placeholder_svg_tag: 'hero__placeholder' }}
        </div>
      {% endif %}

      {% if section.settings.logo_2 %}
        <div class="hero__brand-mark">
          {{ section.settings.logo_2 | image_tag: alt: section.settings.logo_2_alt, loading: 'lazy', decoding: 'async' }}
        </div>
      {% else %}
        <div class="hero__brand-mark hero__brand-mark--placeholder" aria-hidden="true">
          {{ 'image' | placeholder_svg_tag: 'hero__placeholder' }}
        </div>
      {% endif %}
    </div>

    {% if section.settings.header_announcement != blank %}
      <p class="hero__announcement hero__announcement--header">{{ section.settings.header_announcement }}</p>
    {% endif %}

    {% if section.settings.header_button_text != blank %}
      <a href="{{ section.settings.header_button_url | default: '#' }}" class="hero__button hero__button--header" aria-label="{{ section.settings.header_button_text | escape }}">
        {{ section.settings.header_button_text }}
        {% if section.settings.header_arrow_icon %}
          {{ section.settings.header_arrow_icon | image_tag: alt: '', loading: 'lazy', decoding: 'async', class: 'hero__icon' }}
        {% else %}
          <span class="hero__icon hero__icon--placeholder" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'hero__icon-placeholder' }}</span>
        {% endif %}
      </a>
    {% endif %}
  </header>

  <main class="hero__main">
    <div class="hero__content hero__content--mobile">
      {% if section.settings.hero_title != blank %}
        <h1 class="hero__title">{{ section.settings.hero_title }}</h1>
      {% endif %}

      {% if section.settings.hero_description != blank %}
        <p class="hero__description">{{ section.settings.hero_description }}</p>
      {% endif %}
    </div>

    {% if section.settings.cta_button_text != blank %}
      <a href="{{ section.settings.cta_button_url | default: '#' }}" class="hero__button hero__button--cta hero__button--cta-mobile" aria-label="{{ section.settings.cta_button_text | escape }}">
        {{ section.settings.cta_button_text }}
        {% if section.settings.cta_arrow_icon %}
          {{ section.settings.cta_arrow_icon | image_tag: alt: '', loading: 'lazy', decoding: 'async', class: 'hero__icon' }}
        {% else %}
          <span class="hero__icon hero__icon--placeholder" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'hero__icon-placeholder' }}</span>
        {% endif %}
      </a>
    {% endif %}

    <div class="hero__content hero__content--desktop">
      {% if section.settings.hero_title != blank %}
        <h1 class="hero__title">{{ section.settings.hero_title }}</h1>
      {% endif %}

      {% if section.settings.hero_description != blank %}
        <p class="hero__description">{{ section.settings.hero_description }}</p>
      {% endif %}

      {% if section.settings.cta_button_text != blank %}
        <a href="{{ section.settings.cta_button_url | default: '#' }}" class="hero__button hero__button--cta hero__button--cta-desktop" aria-label="{{ section.settings.cta_button_text | escape }}">
          {{ section.settings.cta_button_text }}
          {% if section.settings.cta_arrow_icon %}
            {{ section.settings.cta_arrow_icon | image_tag: alt: '', loading: 'lazy', decoding: 'async', class: 'hero__icon' }}
          {% else %}
            <span class="hero__icon hero__icon--placeholder" aria-hidden="true">{{ 'image' | placeholder_svg_tag: 'hero__icon-placeholder' }}</span>
          {% endif %}
        </a>
      {% endif %}
    </div>

    <div class="hero__media-wrapper">
      <picture class="hero__media">
        {% if section.settings.mobile_image %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 800 }}" />
        {% endif %}

        {% if section.settings.desktop_image %}
          <img
            class="hero__image"
            src="{{ section.settings.desktop_image | image_url: width: 1440 }}"
            srcset="{{ section.settings.desktop_image | image_url: width: 1440 }} 1x, {{ section.settings.desktop_image | image_url: width: 2400 }} 2x"
            alt="{{ section.settings.hero_title | escape }}"
            loading="eager"
            decoding="async"
          />
        {% elsif section.settings.mobile_image %}
          <img
            class="hero__image"
            src="{{ section.settings.mobile_image | image_url: width: 800 }}"
            alt="{{ section.settings.hero_title | escape }}"
            loading="eager"
            decoding="async"
          />
        {% else %}
          <div class="hero__image hero__image--placeholder" aria-hidden="true">
            {{ 'image' | placeholder_svg_tag: 'hero__placeholder-image' }}
          </div>
        {% endif %}
      </picture>
    </div>
  </main>

  {% if section.settings.footer_announcement != blank %}
    <footer class="hero__footer">
      <p class="hero__announcement hero__announcement--footer">{{ section.settings.footer_announcement }}</p>
    </footer>
  {% endif %}
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "logo_1",
      "label": "Logo 1"
    },
    {
      "type": "text",
      "id": "logo_1_alt",
      "label": "Logo 1 alt text",
      "default": "Logo 1"
    },
    {
      "type": "image_picker",
      "id": "logo_2",
      "label": "Logo 2"
    },
    {
      "type": "text",
      "id": "logo_2_alt",
      "label": "Logo 2 alt text",
      "default": "Logo 2"
    },
    {
      "type": "text",
      "id": "header_announcement",
      "label": "Header announcement",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "header_button_text",
      "label": "Header button text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "header_button_url",
      "label": "Header button URL"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "CTA URL"
    },
    {
      "type": "text",
      "id": "footer_announcement",
      "label": "Footer announcement",
      "default": "Sustainable, Ethically Made Clothes In Sizes XS To 6XL"
    },
    {
      "type": "image_picker",
      "id": "header_arrow_icon",
      "label": "Header arrow icon"
    },
    {
      "type": "image_picker",
      "id": "cta_arrow_icon",
      "label": "CTA arrow icon"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
