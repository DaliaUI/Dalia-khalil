      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop all"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "Open in new tab",
          "default": false
        },
        {
          "type": "select",
          "id": "style_class",
          "label": "Style class",
          "options": [
            { "value": "button-custom", "label": "Button custom" },
            { "value": "link", "label": "Link" }
          ],
          "default": "button-custom"
        },
        {
          "type": "color",
          "id": "custom_button_background",
          "label": "Custom button background"
        },
        {
          "type": "color",
          "id": "custom_button_text",
          "label": "Custom button text"
        },
        {
          "type": "color",
          "id": "custom_button_border",
          "label": "Custom button border"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "options": [
            { "value": "fit-content", "label": "Fit content" },
            { "value": "fill", "label": "Fill" }
          ],
          "default": "fit-content"
        },
        {
          "type": "range",
          "id": "custom_width",
          "label": "Custom width",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 100
        },
        {
          "type": "select",
          "id": "width_mobile",
          "label": "Width on mobile",
          "options": [
            { "value": "fit-content", "label": "Fit content" },
