{{ 'hero.css' | asset_url | stylesheet_tag }}

{% style %}
  .hero {
    --hero-padding-top: {{ section.settings.padding_top | default: 0 }}px;
    --hero-padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
  }

  .hero__header {
    background: #fff;
    padding: 20px 24px;
    border-bottom: 1px solid #e5e7eb;
    position: relative;
    z-index: 3;
  }

  .hero__header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 18px;
    max-width: 1440px;
    margin: 0 auto;
  }

  .hero__branding {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hero__brand-mark img {
    display: block;
    max-height: 40px;
    width: auto;
  }

  .hero__announcement--header {
    margin: 0;
    flex: 1;
    min-width: 220px;
    text-align: center;
    font-size: 0.875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #111;
  }

  .hero__button--header {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: #ffeb3b;
    color: #111;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
  }

  .hero__main {
    position: relative;
    overflow: hidden;
    min-height: 560px;
    margin-top: -1px;
  }

  .hero__media-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__media,
  .hero__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.28);
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: min(100%, 720px);
    padding: 80px 24px 64px;
    color: #fff;
  }

  .hero__title {
    margin: 0 0 24px;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1;
    font-weight: 700;
  }

  .hero__description {
    margin: 0 0 32px;
    font-size: 1rem;
    line-height: 1.75;
    max-width: 520px;
  }

  .hero__button--cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background: #000;
    color: #fff;
    text-decoration: none;
    font-weight: 700;
  }

  .hero__footer {
    background: #f5f5f5;
    border-top: 1px solid #e5e7eb;
    padding: 16px 24px;
    text-align: center;
  }

  .hero__footer p {
    margin: 0;
    font-size: 0.875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #111;
  }

  @media screen and (min-width: 768px) {
    .hero__main {
      min-height: 720px;
    }

    .hero__content {
      padding: 120px 40px 80px;
    }
  }
{% endstyle %}

<section id="hero-{{ section.id }}" class="hero">
  <header class="hero__header">
    <div class="hero__header-inner">
      <div class="hero__branding">
        {% if section.settings.logo_1 %}
          <div class="hero__brand-mark">
            {{ section.settings.logo_1 | image_tag: alt: section.settings.logo_1_alt, loading: 'lazy', decoding: 'async' }}
          </div>
        {% else %}
          <div class="hero__brand-mark">
            <img src="{{ 'Group 1000007777.svg' | asset_url }}" alt="{{ section.settings.logo_1_alt | default: 'Logo 1' }}" loading="lazy" decoding="async" />
          </div>
        {% endif %}

        {% if section.settings.logo_2 %}
          <div class="hero__brand-mark">
            {{ section.settings.logo_2 | image_tag: alt: section.settings.logo_2_alt, loading: 'lazy', decoding: 'async' }}
          </div>
        {% endif %}
      </div>

      {% if section.settings.header_announcement != blank %}
        <p class="hero__announcement--header">{{ section.settings.header_announcement | escape }}</p>
      {% endif %}

      {% if section.settings.header_button_text != blank %}
        <a href="{{ section.settings.header_button_url | default: '#' }}" class="hero__button hero__button--header" aria-label="{{ section.settings.header_button_text | escape }}">
          {{ section.settings.header_button_text | escape }}
          {% if section.settings.header_arrow_icon %}
            {{ section.settings.header_arrow_icon | image_tag: alt: '', loading: 'lazy', decoding: 'async', class: 'hero__icon' }}
          {% endif %}
        </a>
      {% endif %}
    </div>
  </header>

  <main class="hero__main">
    <div class="hero__media-wrapper">
      <picture class="hero__media">
        {% if section.settings.mobile_image %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 800 }}" />
        {% endif %}

        {% if section.settings.desktop_image %}
          <img
            class="hero__image"
            src="{{ section.settings.desktop_image | image_url: width: 1440 }}"
            srcset="{{ section.settings.desktop_image | image_url: width: 1440 }} 1x, {{ section.settings.desktop_image | image_url: width: 2400 }} 2x"
            alt="{{ section.settings.hero_title | default: 'Hero image' | escape }}"
            loading="eager"
            decoding="async"
          />
        {% elsif section.settings.mobile_image %}
          <img
            class="hero__image"
            src="{{ section.settings.mobile_image | image_url: width: 800 }}"
            alt="{{ section.settings.hero_title | default: 'Hero image' | escape }}"
            loading="eager"
            decoding="async"
          />
        {% else %}
          <img
            class="hero__image"
            src="{{ 'banner.png' | asset_url }}"
            alt="{{ section.settings.hero_title | default: 'Hero image' | escape }}"
            loading="eager"
            decoding="async"
          />
        {% endif %}
      </picture>
    </div>

    <div class="hero__overlay" aria-hidden="true"></div>

    <div class="hero__content">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'text' %}
              <div class="hero__text-block" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {% when 'button' %}
              <a
                href="{{ block.settings.link | default: '#' }}"
                class="hero__button hero__button--cta {{ block.settings.style_class | default: 'button-custom' }}"
                aria-label="{{ block.settings.label | escape }}"
                {% if block.settings.open_in_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                {{ block.shopify_attributes }}
              >
                <span>{{ block.settings.label | escape }}</span>
              </a>
          {% endcase %}
        {% endfor %}
      {% else %}
        {% if section.settings.hero_title != blank %}
          <h1 class="hero__title">{{ section.settings.hero_title }}</h1>
        {% endif %}

        {% if section.settings.hero_description != blank %}
          <p class="hero__description">{{ section.settings.hero_description }}</p>
        {% endif %}

        {% if section.settings.cta_button_text != blank %}
          <a href="{{ section.settings.cta_button_url | default: '#' }}" class="hero__button hero__button--cta" aria-label="{{ section.settings.cta_button_text | escape }}">
            {{ section.settings.cta_button_text | escape }}
            {% if section.settings.cta_arrow_icon %}
              {{ section.settings.cta_arrow_icon | image_tag: alt: '', loading: 'lazy', decoding: 'async', class: 'hero__icon' }}
            {% endif %}
          </a>
        {% endif %}
      {% endif %}
    </div>
  </main>

  {% if section.settings.footer_announcement != blank %}
    <footer class="hero__footer">
      <p>{{ section.settings.footer_announcement | escape }}</p>
    </footer>
  {% endif %}
</section>

{% schema %}
