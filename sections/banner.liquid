{% liquid
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif

  if section.settings.background_image.alt != blank
    assign background_alt = section.settings.background_image.alt
  else
    assign background_alt = section.settings.heading
  endif
%}

<div
  id="Banner-{{ section.id }}"
  class="gift-banner section-wrapper"
  style="
    --banner-min-height: {{ section.settings.section_height }}px;
    --banner-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --banner-button-bg: {{ section.settings.button_background }};
    --banner-button-text: {{ section.settings.button_text_color }};
    --banner-bottom-bar-bg: {{ section.settings.bottom_bar_background }};
    --banner-bottom-bar-text: {{ section.settings.bottom_bar_text_color }};
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="gift-banner__hero">
    {% if section.settings.background_image != blank %}
      {{
        section.settings.background_image
        | image_url: width: 3840
        | image_tag:
          class: 'gift-banner__background',
          sizes: '100vw',
          widths: '832, 1200, 1600, 1920, 2560, 3840',
          fetchpriority: fetch_priority,
          alt: background_alt
      }}
    {% else %}
      <div class="gift-banner__background gift-banner__background--placeholder" aria-hidden="true"></div>
    {% endif %}

    {% if section.settings.show_overlay %}
      <div class="gift-banner__overlay" aria-hidden="true"></div>
    {% endif %}

    <div class="gift-banner__content page-width">
      <div class="gift-banner__text-group">
       

        {% if section.settings.heading != blank %}
          <h2 class="gift-banner__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="gift-banner__description rte">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="gift-banner__button"
            {% if section.settings.button_open_new_tab %}
              target="_blank"
              rel="noopener noreferrer"
            {% endif %}
          >
            {{ section.settings.button_label }}
            <span class="gift-banner__button-arrow" aria-hidden="true">→</span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  {% if section.settings.bottom_bar_text != blank %}
    <div class="gift-banner__bottom-bar">
      <p class="gift-banner__bottom-bar-text">{{ section.settings.bottom_bar_text }}</p>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .gift-banner {
    width: 100%;
  }

  .gift-banner__hero {
    position: relative;
    min-height: var(--banner-min-height, 520px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .gift-banner[data-shopify-visual-preview] .gift-banner__hero {
    min-height: 520px;
  }

  .gift-banner__background {
    position: absolute;
    inset: 0;
    width: 100%;

    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .gift-banner__background--placeholder {
    background:
      linear-gradient(135deg, #f0f0f0 25%, transparent 25%) -20px 0,
      linear-gradient(225deg, #f0f0f0 25%, transparent 25%) -20px 0,
      linear-gradient(315deg, #f0f0f0 25%, transparent 25%),
      linear-gradient(45deg, #f0f0f0 25%, transparent 25%);
    background-size: 40px 40px;
    background-color: #fafafa;
  }

  .gift-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, var(--banner-overlay-opacity, 0.15));
    z-index: 1;
    pointer-events: none;
  }

  .gift-banner__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-block: 48px;
    padding-inline: var(--page-margin, 20px);
  }

  .gift-banner__text-group {
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .gift-banner__avatars {
    display: flex;
    align-items: center;
  }

  .gift-banner__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #fff;
    background: #e0e0e0;
    overflow: hidden;
    margin-inline-start: -8px;
    flex-shrink: 0;
  }

  .gift-banner__avatar:first-child {
    margin-inline-start: 0;
  }

  .gift-banner__avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gift-banner__avatar-initial {
    font-size: 0.75rem;
    font-weight: 600;
    color: #333;
    text-transform: uppercase;
  }

  .gift-banner__heading {
    margin: 0;
    font-family: var(--font-heading--family, sans-serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #000;
  }

  .gift-banner__description {
    margin: 0;
    font-family: var(--font-body--family, sans-serif);
    font-size: clamp(0.875rem, 2vw, 1rem);
    line-height: 1.6;
    color: #000;
    max-width: 420px;
  }

  .gift-banner__description p {
    margin: 0;
  }

  .gift-banner__button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background-color: var(--banner-button-bg, #000);
    color: var(--banner-button-text, #fff);
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .gift-banner__button:hover {
    opacity: 0.85;
  }

  .gift-banner__button-arrow {
    font-size: 1rem;
    line-height: 1;
  }

  .gift-banner__bottom-bar {
    background-color: var(--banner-bottom-bar-bg, #f0f0f0);
    padding-block: 12px;
    padding-inline: var(--page-margin, 20px);
    text-align: center;
  }

  .gift-banner__bottom-bar-text {
    margin: 0;
    font-family: var(--font-body--family, sans-serif);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--banner-bottom-bar-text, #000);
  }

  @media screen and (max-width: 749px) {
    .gift-banner__hero {
      min-height: calc(var(--banner-min-height, 520px) * 0.75);
    }

    .gift-banner__text-group {
      max-width: 100%;
    }

    .gift-banner__content {
      padding-block: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gift Guide Banner",
  "tag": "section",
  "class": "gift-banner-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Upload your line-art illustration or hero image"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show light overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 15,
      "visible_if": "{{ section.settings.show_overlay }}"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Banner height",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_open_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Avatar icons"
    },
    {
      "type": "checkbox",
      "id": "show_avatars",
      "label": "Show avatar icons",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "avatar_1",
      "label": "Avatar 1 image",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "text",
      "id": "avatar_label_1",
      "label": "Avatar 1 label (if no image)",
      "default": "K",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "image_picker",
      "id": "avatar_2",
      "label": "Avatar 2 image",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "text",
      "id": "avatar_label_2",
      "label": "Avatar 2 label (if no image)",
      "default": "D",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "image_picker",
      "id": "avatar_3",
      "label": "Avatar 3 image",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "text",
      "id": "avatar_label_3",
      "label": "Avatar 3 label (if no image)",
      "default": "+3",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "image_picker",
      "id": "avatar_4",
      "label": "Avatar 4 image",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "text",
      "id": "avatar_label_4",
      "label": "Avatar 4 label (if no image)",
      "visible_if": "{{ section.settings.show_avatars }}"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "bottom_bar_text",
      "label": "Bottom bar text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "color",
      "id": "bottom_bar_background",
      "label": "Bottom bar background",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "bottom_bar_text_color",
      "label": "Bottom bar text color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner",
      "category": "Banners"
    }
  ]
}
{% endschema %}
