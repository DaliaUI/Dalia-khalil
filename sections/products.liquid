{% assign default_heading = section.settings.heading | default: 'Tisso vison in the wild' %}

{% style %}
  .products {
    background: #ffffff;
    color: #111111;
    font-family: 'Jost', sans-serif;
  }

  .products__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 3rem 1.25rem 4rem;
  }

  .products__heading {
    margin: 0 0 1.75rem;
    font-size: clamp(2rem, 3.25vw, 2.25rem);
    line-height: 1.05;
    font-weight: 500;
    font-family: 'Lustria', serif;
  }

  .products__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .products__card {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    min-height: 0;
  }

  .products__image {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .products__button {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.95);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.14);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .products__button:hover {
    transform: translateY(-1px);
    background: #000000;
  }

  .products__button img {
    width: 18px;
    height: 18px;
    display: block;
    filter: invert(0);
    transition: filter 0.2s ease;
  }

  .products__button:hover img {
    filter: invert(1);
  }

  .products__modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 50;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    padding: 1.5rem;
  }

  .products__modal--open {
    display: flex;
  }

 .products__modal-dialog {
  width: 100%;
  max-width: 420px;
  background: #fff;
  padding: 20px;
  border-radius: 0;
  position: relative;
}
.products__modal-top {
  display: flex;
  gap: 16px;
  padding-right: 20px;
}

.products__modal-image {
  width: 120px;
  height: 140px;
  flex-shrink: 0;
  object-fit: cover;
}

.products__modal-title {
  margin: 0 0 8px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.3;
}

.products__modal-price {
  margin: 0 0 12px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.3;
}

.products__modal-description {
    margin: 0;
  font-size: 14px;
  line-height: 1.625;
  color: #000;
}

.products__modal-label {
  display: block;
  margin-top: 20px;
  margin-bottom: 8px;
  font-size: 18px;
  font-weight: 400;
}

.products__modal-color-buttons {
  display: flex;
}

.products__modal-color-button {
  position: relative;
  flex: 1;
  height: 56px;
  border: 1px solid #000;
  background: white;
  padding-left: 20px;
  text-align: left;
  font-size: 20px;
}

.products__modal-color-button.active {
  background: #000;
  color: #fff;
}

.products__modal-color-button::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
}

.products__modal-select {
  width: 100%;
  height: 56px;
  border: 1px solid #000;
  padding: 0 76px 0 16px;
  appearance: none;
  font-size: 20px;
  background: #fff;
}

.products__modal-select-wrapper {
  position: relative;
}

.products__modal-select-icon {
  position: absolute;
  right: 0;
  top: 0;
  padding:1.2rem;
  height: 100%;
  border-left: 1px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
 
}
 .products__modal-select-icon img{
    width:auto;
  }
.products__add-to-cart {
  margin-top: 64px;
  width: 100%;
  height: 64px;
  border: 0;
  background: #000;
  color: #fff;
  font-size: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 18px;
  cursor: pointer;
}
.products__modal-close {
  position: absolute;
  right: 12px;
  top: 4px;
  border: 0;
  background: transparent;
  font-size: 30px;
  font-weight: 300;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

  @media screen and (min-width: 1024px) {
    .products__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }
  .products__modal-color-buttons{
  display:flex;
  gap:0;
  margin-top:8px;
}



.products__modal-color-button.active{
  background:#000;
  color:#fff;
}
.products__modal-color-button{
  position:relative;
  flex:1;
  height:56px;
  border:1px solid #000;
  background:#fff;
  color:#000;
  font-size:20px;
  font-weight:400;
  text-align:left;
  padding-left:18px;
  cursor:pointer;
}

.products__modal-color-button + .products__modal-color-button{
  border-left:0;
}
.products__modal-color-indicator{
  position:absolute;
  left:0;
  top:0;
  bottom:0;
  width:4px;
}

.products__modal-color-indicator--blue{
  background:#2563eb;
}

.products__modal-color-indicator--red{
  background:#dc2626;
}

.products__modal-color-indicator--grey{
  background:#6b7280;
}

.products__modal-color-indicator--black{
  background:#000;
}

.products__modal-color-indicator--white{
  background:#f3f4f6;
  border-right:1px solid #d1d5db;
}
{% endstyle %}

<section id="products-{{ section.id }}" class="products">
  <div class="products__inner">
    <h2 class="products__heading">{{ default_heading }}</h2>

    <div class="products__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% assign image_src = block.settings.image | img_url: '720x' %}
          {% if image_src == blank %}
            {% assign fallback_images = 'image 822.jpg,image 823.jpg,image 824.jpg,image 825.jpg,image 826.jpg,image 827.jpg' | split: ',' %}
            {% assign image_src = fallback_images[forloop.index0] | strip | asset_url %}
          {% endif %}

          <div class="products__card">
            <img
              src="{{ image_src }}"
              alt="{{ block.settings.title | escape }}"
              class="products__image"
            />
            <button
              type="button"
              class="products__button"
              data-product-title="{{ block.settings.title | escape }}"
              data-product-price="{{ block.settings.price | escape }}"
              data-product-description="{{ block.settings.description | escape }}"
              data-product-colors="{{ block.settings.colors | escape }}"
              data-product-sizes="{{ block.settings.sizes | escape }}"
              data-product-variant-id="{{ block.settings.variant_id | escape }}"
              data-product-image="{{ image_src }}"
            >
              <img src="{{ 'icon-plus.svg' | asset_url }}" alt="Open product details" />
            </button>
          </div>
        {% endfor %}
      {% else %}
        <div class="products__card">
          <img src="{{ 'image 822.jpg' | asset_url }}" alt="Tisso Vison product" class="products__image" />
          <button
            type="button"
            class="products__button"
            data-product-title="Tisso Vison Wrap Dress"
            data-product-price="$220"
            data-product-description="This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief."
            data-product-colors="Blue, Red, Grey"
            data-product-sizes="XS, S, M"
            data-product-image="{{ 'image 822.jpg' | asset_url }}"
          >
            <img src="{{ 'icon-plus.svg' | asset_url }}" alt="Open product details" />
          </button>
        </div>

        <div class="products__card">
          <img src="{{ 'image 823.jpg' | asset_url }}" alt="Tisso Vison product" class="products__image" />
          <button
            type="button"
            class="products__button"
            data-product-title="Tisso Vison Leather Tote"
