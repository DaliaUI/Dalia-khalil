{% assign default_heading = section.settings.heading | default: 'Tisso vison in the wild' %}

{% style %}
  .products {
    background: #ffffff;
    color: #111111;
    font-family: 'Jost', sans-serif;
  }

  .products__inner {

    padding: 3rem 3.25rem 4rem;
  }

  .products__heading {
    margin: 0 0 1.75rem;
    font-size: clamp(2rem, 3.25vw, 2.25rem);
    line-height: 1.05;
    font-weight: 500;
    font-family: 'Lustria', serif;
  }

  .products__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .products__card {
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .products__image {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

 .products__button {
  position: absolute;
  width: 22px;
  height: 22px;
  border: 0;
  border-radius: 9999px;
  background: #F8F8F8E5;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 12px 32px rgba(0,0,0,.14);
  transition: transform .2s ease, background-color .2s ease;
  transform: translate(50%, -50%);
}
.products__button--1{
  top:55%;
  right:35%;
}

.products__button--2{
  top:50%;
  right:13%;
}

.products__button--3{
  top:16%;
  right:36%;
}

.products__button--4{
  top:16%;
  right:26%;
}

.products__button--5{
  top:24%;
  right:46%;
}

.products__button--6{
  top:35%;
  right:19%;
}


  .products__button img {
    width: 18px;
    height: 18px;
    display: block;
    filter: invert(0);
    transition: filter 0.2s ease;
  }

  .products__button:hover img {
    filter: invert(1);
  }

  .products__modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 50;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    padding: 1.5rem;
  }

  .products__modal--open {
    display: flex;
  }

 .products__modal-dialog {
  width: 100%;
  max-width: 420px;
  background: #fff;
  padding: 20px;
  border-radius: 0;
  position: relative;
}
.products__modal-top {
  display: flex;
  gap: 16px;
  padding-right: 20px;
}

.products__modal-image {
  width: 120px;
  height: 140px;
  flex-shrink: 0;
  object-fit: cover;
}

.products__modal-title {
  margin: 0 0 8px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.3;
}

.products__modal-price {
  margin: 0 0 12px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.3;
}

.products__modal-description {
    margin: 0;
  font-size: 14px;
  line-height: 1.625;
  color: #000;
}

.products__modal-label {
  display: block;
  margin-top: 20px;
  margin-bottom: 8px;
  font-size: 18px;
  font-weight: 400;
}

.products__modal-color-buttons {
  display: flex;
}


.products__modal-color-button {
  position: relative;
  flex: 1;
  height: 56px;
  border: 1px solid #000;
  background: white;
  padding-left: 20px;
  text-align: left;
  font-size: 20px;
}

.products__modal-color-button.active{
    background:#000;
    color:#fff;
 
}

.products__modal-color-button::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4px;
}

.products__modal-select {
  width: 100%;
  height: 56px;
  border: 1px solid #000;
  padding: 0 76px 0 16px;
  appearance: none;
  font-size: 20px;
  background: #fff;
}

.products__modal-select-wrapper {
  position: relative;
}

.products__modal-select-icon {
  position: absolute;
  right: 0;
  top: 0;
  padding:1.2rem;
  height: 100%;
  border-left: 1px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
 
}
 .products__modal-select-icon img{
    width:auto;
  }
.products__add-to-cart {
  margin-top: 64px;
  width: 100%;
  height: 64px;
  border: 0;
  background: #000;
  color: #fff;
  font-size: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 18px;
  cursor: pointer;
}
.products__modal-close {
  position: absolute;
  right: 12px;
  top: 4px;
  border: 0;
  background: transparent;
  font-size: 30px;
  font-weight: 300;
  line-height: 1;
  cursor: pointer;
  padding: 0;
}

  @media screen and (min-width: 1024px) {
    .products__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }
  }
  .products__modal-color-buttons{
  display:flex;
  gap:0;
  margin-top:8px;
}



.products__modal-color-button.active{
  background:#000;
  color:#fff;
}
.products__modal-color-button{
  position:relative;
  flex:1;
  height:56px;
  border:1px solid #000;
  background:#fff;
  color:#000;
  font-size:20px;
  font-weight:400;
  text-align:left;
  padding-left:18px;
  cursor:pointer;
}

.products__modal-color-button + .products__modal-color-button{
  border-left:0;
}
.products__modal-color-indicator{
  position:absolute;
  left:0;
  top:0;
  bottom:0;
  width:4px;
}

.products__modal-color-indicator--blue{
  background:#2563eb;
}

.products__modal-color-indicator--red{
  background:#dc2626;
}

.products__modal-color-indicator--grey{
  background:#6b7280;
}

.products__modal-color-indicator--black{
  background:#000;
}

.products__modal-color-indicator--white{
  background:#f3f4f6;
  border-right:1px solid #d1d5db;
}
{% endstyle %}

<section id="products-{{ section.id }}" class="products">
  <div class="products__inner">
    <h2 class="products__heading">{{ default_heading }}</h2>

    <div class="products__grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% assign product = block.settings.product %}

{% if product == blank %}
  {% continue %}
{% endif %}

{% assign featured_image = product.featured_image %}

{% if featured_image %}
  {% assign image_src = featured_image | image_url: width: 720 %}
{% else %}
  {% assign image_src = 'image 822.jpg' | asset_url %}
{% endif %}
          <div class="products__card">
            <img
              src="{{ image_src }}"
              alt="{{ product.title | escape }}"
              class="products__image"
            />
            <button
              type="button"
              class="products__button products__button--{{ forloop.index }}"
             data-product-title="{{ product.title | escape }}"
data-product-price="{{ product.price | money }}"
data-product-description="{{ product.description | strip_html | escape }}"
data-product-image="{{ image_src }}"
data-product-variants='{{ product.variants | json | escape }}'
data-product-options='{{ product.options_with_values | json | escape }}'
           
            >
              <img src="{{ 'icon-plus.svg' | asset_url }}" alt="Open product details" />
            </button>
          </div>
        {% endfor %}
      {% else %}
        <div class="products__card">
          <img src="{{ 'image 822.jpg' | asset_url }}" alt="Tisso Vison product" class="products__image" />
          <button
            type="button"
            class="products__button "
            data-product-title="Tisso Vison Wrap Dress"
            data-product-price="$220"
            data-product-description="This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief."
            data-product-colors="Blue, Red, Grey"
