{% schema %}
{
  "name": "t:names.search_input",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "fill",
          "label": "t:options.fill"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "custom"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50,
      "visible_if": "{{ block.settings.width == \"custom\" }}"
    },
    {
      "type": "header",
      "content": "t:content.input"
    },
    {
      "type": "select",
      "id": "input_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "default",
          "label": "t:options.default"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "default",
      "info": "t:info.edit_input_field_in_theme_settings"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "t:settings.background",
      "default": "#FFFFFF",
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "t:settings.text",
      "default": "#000000",
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "t:settings.borders",
      "default": "#000000",
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "t:settings.border_width",
      "min": 0,
      "max": 4,
      "step": 0.5,
      "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.input_style == \"custom\" }}"
    }
  ],
  "presets": []
}
{% endschema %}
